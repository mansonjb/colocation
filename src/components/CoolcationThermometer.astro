---
/**
 * Composant signature : l'échelle de confort coolcation.
 * Au lieu d'opposer la ville à une seule ville-repère, on situe sa maximale de juillet
 * sur une échelle de ressenti : de "frais" à "fournaise". Le message : la ville reste
 * dans la zone de confort estival, loin de la canicule.
 * Accessible : valeur en texte, aria-label, pas de dépendance à la couleur seule.
 */
interface Props {
  cityName: string;
  cityTemp: number;
  note?: string;
}

const { cityName, cityTemp, note } = Astro.props;

// Échelle 15 → 40 °C. Zones (bornes en °C) : frais / confort / chaud / fournaise.
const MIN = 15;
const MAX = 40;
const zones = [
  { key: 'frais', label: 'Frais', from: 15, to: 20 },
  { key: 'confort', label: 'Confort estival', from: 20, to: 28 },
  { key: 'chaud', label: 'Chaud', from: 28, to: 33 },
  { key: 'fournaise', label: 'Fournaise', from: 33, to: 40 },
];
const pct = (t: number) => ((Math.min(MAX, Math.max(MIN, t)) - MIN) / (MAX - MIN)) * 100;
const markerLeft = pct(cityTemp);
const currentZone = zones.find((z) => cityTemp >= z.from && cityTemp < z.to) ?? zones[1];
---

<div
  class="scale-card"
  role="img"
  aria-label={`À ${cityName}, la maximale moyenne de juillet est d'environ ${cityTemp} degrés, dans la zone de confort estival, loin de la fournaise.`}
>
  <h3>Le thermomètre coolcation</h3>
  <p class="sub">Maximale moyenne en juillet, sur l'échelle du ressenti</p>

  <div class="scale">
    <div class="track">
      {
        zones.map((z) => (
          <div
            class:list={['zone', `z-${z.key}`]}
            style={`width:${((z.to - z.from) / (MAX - MIN)) * 100}%`}
          />
        ))
      }
    </div>
    <div class="marker" style={`left:${markerLeft}%`}>
      <span class="bubble">
        <b>{cityName}</b>
        <span class="mtemp">~{cityTemp} °C</span>
      </span>
      <span class="pin" aria-hidden="true"></span>
    </div>
    <div class="ticks" aria-hidden="true">
      <span style="left:20%">20°</span>
      <span style="left:52%">28°</span>
      <span style="left:72%">33°</span>
    </div>
  </div>

  <div class="legend">
    <span><i class="dot z-confort"></i>Zone de confort (20–28 °C)</span>
    <span><i class="dot z-fournaise"></i>Fournaise / canicule (33 °C +)</span>
  </div>

  <p class="verdict">
    {cityName} se situe en <b>{currentZone.label.toLowerCase()}</b>.
  </p>

  {note && <p class="foot">{note}</p>}
</div>

<style>
  .scale-card {
    background: var(--foam);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
    box-shadow: 0 18px 40px -22px rgba(11, 60, 73, 0.5);
  }
  h3 {
    font-size: 1.02rem;
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 700;
    margin-bottom: 4px;
  }
  .sub {
    font-size: 0.82rem;
    color: var(--ink-soft);
    margin-bottom: 40px;
  }
  .scale {
    position: relative;
  }
  .track {
    display: flex;
    height: 14px;
    border-radius: 999px;
    overflow: hidden;
  }
  .zone {
    height: 100%;
  }
  .z-frais {
    background: #cfe4dc;
  }
  .z-confort {
    background: linear-gradient(90deg, var(--seaglass), var(--seaglass-deep));
  }
  .z-chaud {
    background: #e6b36a;
  }
  .z-fournaise {
    background: var(--ochre);
  }
  /* Marqueur de la ville */
  .marker {
    position: absolute;
    top: -6px;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .bubble {
    position: absolute;
    bottom: 22px;
    display: flex;
    flex-direction: column;
    align-items: center;
    white-space: nowrap;
    background: var(--atlantic);
    color: var(--foam);
    padding: 6px 12px;
    border-radius: 10px;
    line-height: 1.15;
    box-shadow: 0 8px 18px -8px rgba(11, 60, 73, 0.7);
  }
  .bubble b {
    font-size: 0.86rem;
    font-weight: 600;
  }
  .bubble .mtemp {
    font-family: 'Spline Sans Mono', monospace;
    font-size: 0.72rem;
    color: var(--seaglass);
  }
  .bubble::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 10px;
    height: 10px;
    background: var(--atlantic);
    border-radius: 2px;
  }
  .pin {
    width: 3px;
    height: 26px;
    background: var(--atlantic);
    border-radius: 999px;
    box-shadow: 0 0 0 3px var(--foam);
  }
  .ticks {
    position: relative;
    height: 16px;
    margin-top: 6px;
  }
  .ticks span {
    position: absolute;
    transform: translateX(-50%);
    font-family: 'Spline Sans Mono', monospace;
    font-size: 0.62rem;
    color: var(--ink-soft);
  }
  .legend {
    display: flex;
    gap: 16px;
    margin-top: 14px;
    font-size: 0.76rem;
    color: var(--ink-soft);
    flex-wrap: wrap;
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 3px;
    display: inline-block;
    margin-right: 6px;
    vertical-align: middle;
  }
  .dot.z-confort {
    background: var(--seaglass-deep);
  }
  .dot.z-fournaise {
    background: var(--ochre);
  }
  .verdict {
    margin-top: 16px;
    font-size: 0.92rem;
    color: var(--ink);
  }
  .verdict b {
    color: var(--seaglass-deep);
  }
  .foot {
    margin-top: 12px;
    font-size: 0.78rem;
    color: var(--ink-soft);
    border-top: 1px dashed var(--line);
    padding-top: 12px;
  }
</style>
