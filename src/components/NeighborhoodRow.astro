---
import AffiliateLink from './AffiliateLink.astro';

/** Ligne du comparatif de quartiers, avec CTA affilié */
interface Props {
  name: string;
  tag: string;
  description: string;
  affiliateUrl: string;
}

const { name, tag, description, affiliateUrl } = Astro.props;
---

<div class="hood">
  <div>
    <span class="htag">{tag}</span><span class="hname">{name}</span>
  </div>
  <div class="hdesc">{description}</div>
  <div class="hcta">
    <AffiliateLink href={affiliateUrl} ariaLabel={`Voir les disponibilités : ${name}`}>
      Disponibilités
    </AffiliateLink>
  </div>
</div>

<style>
  .hood {
    display: grid;
    grid-template-columns: 180px 1fr auto;
    gap: 22px;
    align-items: center;
    padding: 22px 24px;
    background: var(--foam);
  }
  .hood:not(:last-child) {
    border-bottom: 1px solid var(--line);
  }
  .hood:nth-child(even) {
    background: rgba(242, 235, 221, 0.4);
  }
  .hname {
    font-family: 'Fraunces', serif;
    font-size: 1.22rem;
    font-weight: 600;
  }
  .htag {
    font-family: 'Spline Sans Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--seaglass-deep);
    display: block;
    margin-bottom: 3px;
  }
  .hdesc {
    font-size: 0.94rem;
    color: var(--ink-soft);
  }
  .hcta {
    white-space: nowrap;
  }
  .hcta :global(a),
  .hcta :global(span) {
    font-size: 0.86rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--atlantic);
    border: 1.5px solid var(--line);
    padding: 9px 15px;
    border-radius: 999px;
    display: inline-block;
    transition: border-color 0.15s;
  }
  .hcta :global(a:hover) {
    border-color: var(--atlantic);
  }
  @media (max-width: 760px) {
    .hood {
      grid-template-columns: 1fr;
      gap: 10px;
    }
  }
</style>
