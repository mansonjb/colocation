---
/** Maillage interne : bloc "à lire ensuite" */
interface Props {
  title?: string;
  links: { label: string; href: string }[];
}

const { title = 'À lire ensuite', links } = Astro.props;
---

{
  links.length > 0 && (
    <nav class="related-block reveal" aria-label={title}>
      <p class="eyebrow">{title}</p>
      <div class="related">
        {links.map((l) => (
          <a href={l.href}>{l.label}</a>
        ))}
      </div>
    </nav>
  )
}

<style>
  .related-block {
    margin-top: 40px;
  }
  .related {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 14px;
  }
  .related a {
    font-size: 0.9rem;
    text-decoration: none;
    color: var(--atlantic);
    background: rgba(95, 180, 162, 0.12);
    padding: 8px 14px;
    border-radius: 999px;
    font-weight: 500;
  }
  .related a:hover {
    background: rgba(95, 180, 162, 0.24);
  }
</style>
