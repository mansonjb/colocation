---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CoolcationThermometer from '../../components/CoolcationThermometer.astro';
import ProfileCard from '../../components/ProfileCard.astro';
import NeighborhoodRow from '../../components/NeighborhoodRow.astro';
import SeasonCalendar from '../../components/SeasonCalendar.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import AffiliateLink from '../../components/AffiliateLink.astro';
import Disclosure from '../../components/Disclosure.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import DestinationImage from '../../components/DestinationImage.astro';
import HotelCard from '../../components/HotelCard.astro';
import { touristDestination } from '../../lib/jsonld';
import { hotelsFor } from '../../lib/hotels';

export async function getStaticPaths() {
  const destinations = await getCollection('destinations', ({ data }) => !data.draft);
  const all = await getCollection('destinations');
  return destinations.map((d) => ({
    params: { slug: d.data.slug },
    props: { d, all },
  }));
}

const { d, all } = Astro.props;
const dest = d.data;
const c = dest.coolcation;

const title = `Où dormir à ${dest.name} : la coolcation idéale (soleil, sans la fournaise)`;
const description = `Le bon quartier où loger à ${dest.name} selon votre profil. ${dest.intro}`.slice(0, 158);

// Maillage : destinations liées (publiées uniquement) + hub + guide pilier
const related = dest.related_slugs
  .map((slug) => all.find((x) => x.data.slug === slug))
  .filter((x) => x && !x.data.draft)
  .map((x) => ({ label: `Où dormir à ${x!.data.name}`, href: `/destinations/${x!.data.slug}/` }));
const relatedLinks = [
  ...related,
  { label: "Qu'est-ce que la coolcation ?", href: '/thematiques/coolcation/' },
  {
    label: "Où partir au frais l'été sans quitter le soleil",
    href: '/guides/ou-partir-au-frais-l-ete/',
  },
];

/** "2 110 h de soleil par an, ..." → { num: "2 110 h", lab: "de soleil par an, ..." } */
function splitStat(point: string): { num: string; lab: string } {
  const m = point.match(/^([\d\s .,]+(?:h|°C|km\/h)?)\s+(.*)$/u);
  return m ? { num: m[1].trim(), lab: m[2] } : { num: '', lab: point };
}

// Note du thermomètre (cadrage "zone de confort"). Le message s'adapte à l'ensoleillement :
// destinations lumineuses = "autant de soleil que le Sud" ; destinations plus fraîches et au ciel
// changeant (îles Britanniques) = "grand air". Le complément "brise" n'apparaît que si une valeur
// de brise fiable est renseignée (littoral).
const sunny = (c.sun_hours_year ?? 0) >= 1800;
const thermoBase = sunny
  ? 'Autant de soleil que le Sud, sans les pics à 32-35 °C des étés en canicule'
  : 'Un été vraiment frais et du grand air, à mille lieues des canicules du Sud';
const thermoNote =
  c.july_max_avg != null
    ? thermoBase + (c.breeze_kmh != null ? ', et une brise qui rafraîchit les après-midis.' : '.')
    : '';

// Libellé des zones (quartier / secteur) et son pluriel.
const areaLabel = dest.area_label;
const areaPlural = `${areaLabel}s`;

const hotels = hotelsFor(dest.slug);

const jsonLd = [touristDestination(dest)];
---

<Base title={title} description={description} jsonLd={jsonLd} ogType="article">
  <header class="hero">
    <div class="wrap">
      <Breadcrumbs
        crumbs={[
          { name: 'Accueil', href: '/' },
          { name: 'Destinations', href: '/destinations/' },
          { name: dest.name, href: `/destinations/${dest.slug}/` },
        ]}
      />
    </div>
    <div class="wrap hero-grid">
      <div>
        <p class="eyebrow">Guide hébergement · {dest.region}</p>
        <h1>Où dormir à {dest.name}, <em>{dest.hero_tagline}</em>.</h1>
        <p class="lede">{dest.intro}</p>
        <div class="hero-cta">
          <a class="btn btn-primary" href="#profils">Trouver mon quartier →</a>
          <a class="btn btn-ghost" href="#saison">La meilleure période</a>
        </div>
      </div>
      {
        c.july_max_avg != null && (
          <CoolcationThermometer cityName={dest.name} cityTemp={c.july_max_avg} note={thermoNote} />
        )
      }
    </div>
    {
      dest.hero_image && (
        <div class="wrap hero-photo reveal">
          <DestinationImage image={dest.hero_image} variant="hero" eager />
        </div>
      )
    }
  </header>

  {
    c.proof_points.length > 0 && (
      <section class="proof">
        <div class="wrap reveal">
          <p class="eyebrow">Pourquoi c'est une destination coolcation</p>
          <div class="proof-grid">
            {c.proof_points.map((point) => {
              const s = splitStat(point);
              return (
                <div class="stat">
                  <div class="num">{s.num}</div>
                  <div class="lab">{s.lab}</div>
                </div>
              );
            })}
          </div>
        </div>
      </section>
    )
  }

  <section class="sec" id="profils">
    <div class="wrap">
      <div class="sec-head reveal">
        <p class="eyebrow">L'essentiel</p>
        <h2>Où loger selon votre façon de voyager ?</h2>
        <p>
          Pas de « top 10 des hôtels ». La vraie question, c'est <i>où</i> poser vos valises pour que
          le séjour colle à vos envies. Voici notre lecture par profil.
        </p>
      </div>
      <div class="profiles">
        {
          dest.profiles.map((p) => (
            <ProfileCard
              profile={p.profile}
              neighborhood={p.neighborhood}
              reason={p.reason}
              affiliateUrl={p.affiliate_url}
              ctaLabel={`Voir les logements : ${p.neighborhood} →`}
            />
          ))
        }
      </div>
    </div>
  </section>

  {
    dest.neighborhoods.length > 0 && (
      <section class="sec no-pt" id="quartiers">
        <div class="wrap">
          <div class="sec-head reveal">
            <p class="eyebrow">En détail</p>
            <h2>Les {dest.neighborhoods.length} {areaPlural}, comparés</h2>
            <p>Ambiance, à qui ça convient, et ce qu'il y a autour.</p>
          </div>
          <div class="hoods reveal">
            {dest.neighborhoods.map((n) => (
              <NeighborhoodRow
                name={n.name}
                tag={n.tag}
                description={n.description}
                affiliateUrl={n.affiliate_url}
              />
            ))}
          </div>
        </div>
      </section>
    )
  }

  {
    hotels.length > 0 && (
      <section class="sec no-pt" id="hotels">
        <div class="wrap">
          <div class="sec-head reveal">
            <p class="eyebrow">Où réserver</p>
            <h2>Des hébergements bien notés à {dest.name}</h2>
            <p>
              Une sélection d'hôtels réels de la ville, parmi les mieux notés. Comparez les
              disponibilités et les prix via notre partenaire, puis affinez avec les quartiers
              ci-dessus selon votre profil.
            </p>
          </div>
          <div class="hotels reveal">
            {hotels.map((h) => (
              <HotelCard hotel={h} cityName={dest.name} />
            ))}
          </div>
          {dest.affiliate.booking_search_url && (
            <p class="hotels-all reveal">
              <AffiliateLink href={dest.affiliate.booking_search_url} class="btn btn-ghost">
                Voir tous les hébergements à {dest.name} →
              </AffiliateLink>
            </p>
          )}
        </div>
      </section>
    )
  }

  <section class="sec no-pt" id="saison">
    <div class="wrap">
      <SeasonCalendar
        idealMonths={dest.season.ideal_months}
        peakMonths={dest.season.peak_months}
        text="Le secret coolcation : les ailes de saison (mai-juin et septembre) offrent un climat doux, des prix plus bas et bien moins de monde que le pic estival, sans rien sacrifier au soleil."
      />
    </div>
  </section>

  <section class="sec no-pt" id="faq">
    <div class="wrap">
      <div class="sec-head reveal">
        <p class="eyebrow">Questions fréquentes</p>
        <h2>Avant de réserver</h2>
      </div>
      <FaqAccordion faq={dest.faq} />

      {
        dest.affiliate.booking_search_url && (
          <p class="all-cta reveal">
            <AffiliateLink href={dest.affiliate.booking_search_url} class="btn btn-primary">
              Voir tous les hébergements à {dest.name} →
            </AffiliateLink>
          </p>
        )
      }

      <Disclosure />
      <RelatedLinks links={relatedLinks} />
      <p class="updated">
        Dernière mise à jour : {dest.updated.toLocaleDateString('fr-FR', { dateStyle: 'long' })} · {dest.author}
      </p>
    </div>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(120% 90% at 85% -10%, rgba(95, 180, 162, 0.2), transparent 60%),
      linear-gradient(180deg, var(--sandstone), var(--foam));
    padding: 10px 0 64px;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 48px;
    align-items: center;
    margin-top: 44px;
  }
  @media (max-width: 860px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
  .hero h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin: 14px 0 18px;
  }
  .hero h1 em {
    font-style: italic;
    color: var(--seaglass-deep);
  }
  .hero .lede {
    max-width: 32ch;
  }
  .hero-cta {
    margin-top: 28px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .hero-photo {
    margin-top: 44px;
  }
  .proof {
    padding: 54px 0;
    border-bottom: 1px solid var(--line);
  }
  .proof-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-top: 26px;
  }
  @media (max-width: 760px) {
    .proof-grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }
  }
  .stat {
    padding: 22px;
    border-left: 3px solid var(--seaglass);
    background: linear-gradient(180deg, rgba(95, 180, 162, 0.06), transparent);
  }
  .stat .num {
    font-family: 'Fraunces', serif;
    font-size: 2.1rem;
    font-weight: 600;
    color: var(--atlantic);
  }
  .stat .lab {
    font-size: 0.94rem;
    color: var(--ink-soft);
    margin-top: 2px;
  }
  .profiles {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: 34px;
  }
  @media (max-width: 760px) {
    .profiles {
      grid-template-columns: 1fr;
    }
  }
  .hoods {
    margin-top: 30px;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .no-pt {
    padding-top: 0;
  }
  .hotels {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 30px;
  }
  @media (max-width: 860px) {
    .hotels {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .hotels {
      grid-template-columns: 1fr;
    }
  }
  .hotels-all {
    margin-top: 26px;
  }
  .all-cta {
    margin-top: 34px;
  }
  .updated {
    margin-top: 26px;
    font-size: 0.8rem;
    color: var(--ink-soft);
  }
</style>
