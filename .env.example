# URL de production (utilisée pour canonical, sitemap, OpenGraph)
SITE_URL=https://www.capaufrais.fr

# IDs d'affiliation : jamais en dur dans le contenu ni les templates.
# Laisser vide en dev : les liens sortent sans tag partenaire.
PUBLIC_BOOKING_AID=
PUBLIC_HOMETOGO_REF=
PUBLIC_GYG_PARTNER_ID=

# Stay22 : ID partenaire (public, visible dans les URLs sortantes). Défaut : "capaufrais".
PUBLIC_STAY22_AID=

# Token Apify — UNIQUEMENT pour le script de scrape d'hôtels (scripts/fetch-hotels.mjs),
# jamais utilisé au build ni exposé côté client. Ne pas committer la vraie valeur.
# APIFY_TOKEN=
